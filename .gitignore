# API proxy (separate service, not part of main app)
api-proxy/

# Python memex (separate service)
memex/
src-tauri/memex/
memex/__pycache__/
*.pyc

# Docs (AI-generated design specs, not needed in repo)
docs/

# Artifacts (build outputs)
public/artifacts/code/
public/artifacts/previews/

# Design assets (large static files, not needed in repo)
public/design-assets/

# Worker output
src/workers/*.js

# Data files (remixed json, runtime generated)
src/data/remixed-*.json
src/data/_index.json

# Standalone mini-apps (not part of main client)
src-tauri/prd-creator/
src-tauri/remotion-studio/
